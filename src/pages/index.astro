---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { fetchPosts } from "../lib/api";
import type { BlogPost } from "../types";

const posts: BlogPost[] = await fetchPosts();
---

<BaseLayout>
  <Header slot="header" />

  <!-- Hero Section (Blue Background) -->
  <section class="bg-blue-600 py-16 text-white">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Welcome to Corrison</h1>
      <p class="text-xl mb-8">
        Your trusted partner for innovative digital solutions
      </p>

      <p class="text-lg max-w-3xl mx-auto mb-10">
        Our science-backed platform is built on the principles of behavioral
        economics to work for the hardest-to-reach populations.
      </p>

      <div class="flex justify-center">
        <a
          href="/pages"
          class="bg-white text-blue-600 hover:bg-blue-100 transition-colors duration-300 font-medium py-3 px-6 rounded-full"
        >
          Explore the Corrison platform
        </a>
      </div>
    </div>
  </section>

  <!-- Content with Image Section -->
  <section class="py-20">
    <div class="container mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center gap-12">
        <!-- Image -->
        <div class="w-full md:w-1/2">
          <img src="/images/img1.webp" alt="Hero image" />
        </div>

        <!-- Text Content -->
        <div class="w-full md:w-1/2">
          <h2 class="text-3xl md:text-4xl font-bold mb-6">
            Healthier behaviors at population-scale
          </h2>
          <p class="text-gray-700 text-lg mb-4">
            Corrison gives hard-to-reach and complex populations a motivating
            and rewarding experience daily to improve health, cost, and quality
            outcomes. Our programs break through the noise, engaging members
            that traditional strategies have failed to reach.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Green Stats Section -->
  <section class="bg-green-500 py-16">
    <div class="container mx-auto px-4">
      <div
        class="bg-white rounded-lg shadow-lg p-8 max-w-2xl mx-auto text-center"
      >
        <h2 class="text-2xl md:text-3xl font-medium mb-6">
          We only get paid when you see care plan adherence.
        </h2>

        <p class="text-xl">
          Corrison's partners have given over $15,000,000 in rewards back to
          their members for daily healthy behaviors.
        </p>
      </div>
    </div>
  </section>

  <!-- How It Works Section with Three Boxes -->
  <section class="py-20">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center">
        How it works
      </h2>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Box 1 -->
        <div class="bg-gray-50 p-8 rounded-lg text-center">
          <div
            class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-8 w-8 text-green-500"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
          </div>
          <p class="text-gray-700">
            We help people with chronic conditions, barriers to accessing
            healthcare, and distrust of the medical system...
          </p>
        </div>

        <!-- Box 2 -->
        <div class="bg-gray-50 p-8 rounded-lg text-center">
          <div
            class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-8 w-8 text-green-500"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
              ></path>
            </svg>
          </div>
          <p class="text-gray-700">
            ...prioritize their care plans every day by taking medications,
            monitoring conditions, and getting preventative screenings...
          </p>
        </div>

        <!-- Box 3 -->
        <div class="bg-gray-50 p-8 rounded-lg text-center">
          <div
            class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-8 w-8 text-green-500"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <p class="text-gray-700">
            ...to help organizations meet and exceed goals for cost, quality,
            and health outcomes.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What Motivates Us Section -->
  <section class="py-12">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold mb-10 text-center">
        What motivates us
      </h2>
      <!-- Add content here -->
    </div>
  </section>

  <!-- Latest Blog Posts Section -->
  <section class="bg-gray-100 py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold mb-8 text-center">Latest from Our Blog</h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          posts.slice(0, 3).map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow"
            >
              {post.featured_image && (
                <img
                  src={post.featured_image}
                  alt={post.title}
                  class="w-full h-48 object-cover"
                />
              )}
              <div class="p-6">
                <h3 class="text-xl font-semibold mb-2">{post.title}</h3>
                <time class="text-sm text-gray-500 block mb-4">
                  {new Date(post.created_at).toLocaleDateString()}
                </time>
                <div class="text-blue-600 font-medium text-sm">Read more →</div>
              </div>
            </a>
          ))
        }
      </div>

      <div class="text-center mt-10">
        <a
          href="/blog"
          class="inline-block bg-blue-600 text-white py-2 px-6 rounded-md hover:bg-blue-700 transition-colors"
        >
          View all posts
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
