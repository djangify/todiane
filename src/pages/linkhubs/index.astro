---
// src/pages/linkhubs/[slug].astro

import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import type { LinkHub, Link } from "../../types";
import { fetchLinkHub } from "../../lib/api";

const slug = Astro.params.slug!;
const hub: LinkHub = await fetchLinkHub(slug);
---

<BaseLayout>
  <Header slot="header" />
  <h1 slot="title">{hub.title}</h1>

  <ul class="space-y-2">
    {
      hub.links.map((link: Link) => (
        <li>
          <a
            href={link.url}
            target="_blank"
            rel="noopener"
            class="text-blue-600 hover:underline"
          >
            {link.title}
          </a>
        </li>
      ))
    }
  </ul>

  <Footer slot="footer" />
</BaseLayout>
