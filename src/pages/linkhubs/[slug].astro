---
import type { LinkHub } from "../../types";
import { fetchLinkHub } from "../../lib/api";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const slug = Astro.params.slug!;
const hub: LinkHub = await fetchLinkHub(slug);
---

<BaseLayout>
  <Header slot="header" />
  <section class="container mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-6">{hub.title}</h1>
    <ul class="space-y-2">
      {
        hub.links.map((link) => (
          <li>
            <a
              href={link.url}
              target="_blank"
              rel="noopener"
              class="text-blue-600 hover:underline"
            >
              {link.title}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
  <Footer slot="footer" />
</BaseLayout>
