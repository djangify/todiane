---
import type { Page } from "../../types";
import { fetchPage } from "../../lib/api";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const slug = Astro.params.slug!;
const page: Page = await fetchPage(slug);
---

<BaseLayout>
  <Header slot="header" />
  <title slot="title">{page.title} – Corrison</title>

  <div class="container mx-auto px-4 py-12">
    <div class="max-w-4xl mx-auto">
      <!-- Hero Image if available -->
      {
        page.hero_image && (
          <div class="w-full h-[400px] overflow-hidden rounded-xl mb-10">
            <img
              src={page.hero_image}
              alt={page.title}
              class="w-full h-full object-cover"
            />
          </div>
        )
      }

      <!-- Content Header -->
      <header class="mb-10">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">{page.title}</h1>
        {page.subtitle && <p class="text-xl text-gray-600">{page.subtitle}</p>}
      </header>

      <!-- Main Content -->
      <article class="prose prose-lg max-w-none mb-12">
        <div set:html={page.content} />
      </article>

      <!-- Last Updated Info -->
      <div class="mt-16 pt-8 border-t border-gray-200">
        <p class="text-sm text-gray-500">
          Last updated: {
            new Date(page.updated_at).toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </p>
      </div>

      <!-- Back to pages -->
      <div class="mt-8">
        <a
          href="/pages"
          class="inline-flex items-center text-blue-600 hover:text-blue-800 transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5 mr-2"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Back to All Pages
        </a>
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
