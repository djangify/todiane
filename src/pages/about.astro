---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { fetchPage } from "../lib/api";
import type { Page } from "../types";

// Fetch the "about" page data
const page = await fetchPage("about");
---

<BaseLayout>
  <Header slot="header" />
  <title slot="title">{page.title} – Corrison</title>

  {/* Hero Section */}
  {
    page.hero_title && (
      <section class="bg-gray-100 py-12">
        <div class="container mx-auto px-4">
          <div class="flex flex-col md:flex-row items-center">
            {page.hero_image && (
              <div class="md:w-1/2 mb-8 md:mb-0">
                <img
                  src={page.hero_image}
                  alt={page.hero_title}
                  class="rounded-lg shadow-lg"
                />
              </div>
            )}
            <div class="md:w-1/2 md:pl-8">
              <h1 class="text-4xl font-bold mb-4">{page.hero_title}</h1>
              {page.hero_subtitle && (
                <p class="text-xl text-gray-600 mb-6">{page.hero_subtitle}</p>
              )}
              <div class="prose max-w-none" set:html={page.hero_content} />
            </div>
          </div>
        </div>
      </section>
    )
  }

  {/* Main Content */}
  <div class="container mx-auto px-4 py-12">
    {!page.hero_title && <h1 class="text-4xl font-bold mb-8">{page.title}</h1>}
    {
      page.subtitle && (
        <p class="text-xl text-gray-600 max-w-3xl mb-8">{page.subtitle}</p>
      )
    }
    <div class="prose max-w-none" set:html={page.content} />
  </div>

  {/* Feature Section (only if enabled) */}
  {
    page.has_feature_section && (
      <section class="py-20 bg-gray-50">
        <div class="container mx-auto px-4">
          <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center">
            {page.feature_section_title}
          </h2>

          <div class="grid md:grid-cols-3 gap-8">
            {page.features &&
              page.features.map((feature) => (
                <div class="bg-white p-8 rounded-lg shadow-sm text-center">
                  <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-8 w-8 text-green-500"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d={
                          feature.icon ||
                          "M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                        }
                      />
                    </svg>
                  </div>
                  {feature.title && (
                    <h3 class="text-xl font-semibold mb-3">{feature.title}</h3>
                  )}
                  <p class="text-gray-700">{feature.content}</p>
                </div>
              ))}
          </div>
        </div>
      </section>
    )
  }

  <Footer slot="footer" />
</BaseLayout>
